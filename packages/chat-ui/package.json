{
  "name": "@vectordev2001/chat-ui",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/types/*.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json || echo 'chat-ui: build:types reported pre-existing type errors (see tsc baseline) but .d.ts files were still emitted since noEmitOnError is off — not a build failure'",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "5.6.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}

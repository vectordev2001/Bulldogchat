# --- Vector Chat — environment configuration ---
# Copy to .env for local dev. On Render, set these in the dashboard or render.yaml.

# Core
NODE_ENV=development
PORT=5000

# SQLite database file path (relative or absolute).
# Local dev default: ./data/vector.db. Production (Render disk): file:/app/data/vector.db
DATABASE_URL=file:./data/vector.db

# JSON Web Token signing secret. MUST be a long random string in production.
# Render: set generateValue: true to have Render generate one for you.
JWT_SECRET=replace-me-with-a-long-random-string

# Auth mode for the frontend:
#   "bearer" (default for local sandbox) — token stored in memory, sent via Authorization header.
#   "cookie" (recommended for production) — backend sets vc_token HttpOnly cookie.
VITE_AUTH_MODE=bearer

# --- LiveKit (optional — voice/video) ---
# Sign up at https://livekit.io and create a project to get these values.
# When unset, voice channels run in safe "demo mode" with a banner — no errors.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# --- Web Push (optional — desktop/mobile notifications) ---
# Generate a VAPID keypair locally:  npx web-push generate-vapid-keys
# Then paste public+private here. Also expose the public key to the frontend as VITE_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:chat@bulldogops.com
VITE_VAPID_PUBLIC_KEY=

# --- File attachments storage ---
# "disk" writes uploads to ./data/uploads (or /app/data/uploads on Render disk).
# "s3" stores uploads (and LiveKit recordings) in S3-compatible storage.
STORAGE_BACKEND=disk

# Disk backend: directory uploads are written to. Defaults to /app/data/uploads.
LOCAL_UPLOAD_ROOT=

# S3 / R2 / MinIO / Synology — fill these in when STORAGE_BACKEND=s3.
# Recordings always go to S3 (LiveKit egress cannot write to local disk).
S3_ENDPOINT=                  # e.g. https://s3.us-east-1.amazonaws.com or https://<account>.r2.cloudflarestorage.com
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL_BASE=           # optional: e.g. https://cdn.example.com (used to build public attachment URLs)
S3_KEY_PREFIX=                # optional: namespace all object keys, e.g. chat/

# --- LiveKit webhook (optional) ---
# Used to verify egress completion callbacks from LiveKit Cloud.
LIVEKIT_WEBHOOK_KEY=

# --- Cross-app SMS notifications (Bulldog Chat → Bulldog Ops) ---
# Chat emits channel_add and meeting_invite events to Bulldog Ops, which owns
# the unified, consent-gated SMS sender + escalation worker. Keyed on email.
# OPS_NOTIFY_URL=https://ops.bulldogops.com/api/notifications/emit
# Shared secret — MUST match INBOUND_NOTIFICATION_TOKEN set on bulldog-ops.
# Generate with: openssl rand -hex 32   (NEVER commit the real value)
# INBOUND_NOTIFICATION_TOKEN=change-me
